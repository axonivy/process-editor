{
  "private": true,
  "name": "@axonivy/process-editor-root",
  "version": "10.0.1",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci",
    "clean": "pnpm run -r clean",
    "build": "tsc --build",
    "build:icons": "pnpm run --filter @axonivy/process-editor build:icons",
    "package": "pnpm run -r package",
    "type": "pnpm run -r type",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "dev": "pnpm run --filter @axonivy/process-editor-standalone dev",
    "dev:eclipse": "pnpm run --filter @axonivy/process-editor-eclipse dev",
    "test": "pnpm run --filter @axonivy/process-editor test",
    "test:ci": "pnpm run --filter @axonivy/process-editor test:ci",
    "webtest": "pnpm run --filter @axonivy/process-editor-standalone webtest"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.21.0",
    "eslint-formatter-checkstyle": "^8.40.0",
    "eslint-plugin-playwright": "^2.1.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.1.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vite-plugin-node-polyfills": "^0.28.0",
    "setimmediate": "^1.0.5"
  }
}
